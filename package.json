{
  "name": "openflow-studio",
  "version": "2.1.0",
  "description": "OpenFlow Studio — AIGC 广告生产力工作流工具",
  "author": "mxw86",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/MXWStudio/OpenFlow.git"
  },
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && electron-builder --win",
    "preview": "electron-vite preview",
    "lint": "tsc --noEmit"
  },
  "build": {
    "appId": "com.openflow.studio",
    "publish": [
      {
        "provider": "github",
        "owner": "MXWStudio",
        "repo": "OpenFlow"
      }
    ],
    "win": {
      "icon": "icons/icon.png",
      "target": [
        "nsis"
      ]
    },
    "directories": {
      "output": "build-dist"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "OpenFlow Studio"
    }
  },
  "dependencies": {
    "@dicebear/core": "^9.4.0",
    "@dicebear/dylan": "^9.4.0",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@google/genai": "^1.29.0",
    "@hello-pangea/dnd": "^18.0.1",
    "@mantine/core": "^8.3.18",
    "@mantine/dropzone": "^8.3.18",
    "@mantine/hooks": "^8.3.18",
    "@mantine/notifications": "^8.3.18",
    "@tanstack/react-table": "^8.21.3",
    "electron-updater": "^6.8.3",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "framer-motion": "^12.36.0",
    "fs-extra": "^11.2.0",
    "image-size": "^1.1.1",
    "konva": "^10.2.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pinyin-pro": "^3.28.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-konva": "^19.2.3",
    "recharts": "^3.8.1",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "sqlite3": "^6.0.1",
    "use-image": "^1.1.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.14.0",
    "@types/sqlite3": "^3.1.11",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "electron": "^33.0.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^2.3.0",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2"
  }
}
